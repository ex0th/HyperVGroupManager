<Window x:Class="HyperVGroupManager.App.Views.NewGroupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Neue Gruppe" Height="170" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Name der neuen Gruppe:" Margin="0,0,0,6" />
        <TextBox x:Name="GroupNameTextBox" Grid.Row="1" Margin="0,0,0,6" />
        <TextBlock Grid.Row="2" Text="Tipp: Das Präfix VEEAM_ wird empfohlen, ist aber nicht erforderlich."
                   Foreground="Gray" TextWrapping="Wrap" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="80" Margin="0,0,6,0" IsDefault="True" Click="OkButton_Click" />
            <Button Content="Abbrechen" Width="80" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
