<Window x:Class="HyperVGroupManager.App.Views.DeleteGroupConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gruppe löschen" Height="180" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel x:Name="ConfirmationPanel" Grid.Row="0">
            <TextBlock TextWrapping="Wrap">
                <TextBlock Text="Soll die Gruppe '" /><TextBlock x:Name="ConfirmGroupNameText" FontWeight="Bold" /><TextBlock Text="' wirklich gelöscht werden?" />
            </TextBlock>
            <TextBlock Text="Diese Gruppe ist leer (0 Mitglieder)." Margin="0,10,0,0" Foreground="Gray" />
        </StackPanel>

        <StackPanel x:Name="BlockedPanel" Grid.Row="0" Visibility="Collapsed">
            <TextBlock TextWrapping="Wrap">
                <TextBlock Text="Die Gruppe '" /><TextBlock x:Name="BlockedGroupNameText" FontWeight="Bold" /><TextBlock Text="' enthält noch " />
                <TextBlock x:Name="MemberCountText" FontWeight="Bold" /><TextBlock Text=" Mitglied(er) und kann nicht gelöscht werden." />
            </TextBlock>
            <TextBlock Text="Entfernen Sie zuerst alle Mitgliedschaften, bevor Sie die Gruppe löschen." Margin="0,10,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="ConfirmButton" Content="Löschen" Width="80" Margin="0,0,6,0" Click="ConfirmButton_Click" />
            <Button x:Name="CloseButton" Content="Abbrechen" Width="80" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
