<Window x:Class="HyperVGroupManager.App.Views.ClusterConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cluster-Konfiguration" Height="320" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Aktueller Wert -->
        <TextBlock Grid.Row="0" Text="Aktueller ConfigStoreRootPath:" FontWeight="Bold" Margin="0,0,0,4" />
        <Border Grid.Row="1" Background="#FFF0F0F0" BorderBrush="#FFCCCCCC" BorderThickness="1" Padding="6,4" Margin="0,0,0,12">
            <TextBlock x:Name="CurrentPathTextBlock" TextWrapping="Wrap" Text="(wird geladen...)" Foreground="Gray" />
        </Border>

        <!-- Eingabe neuer Pfad -->
        <TextBlock Grid.Row="2" x:Name="NewPathLabel" Text="Neuer Pfad:" Margin="0,0,0,4" />
        <TextBox x:Name="PathTextBox" Grid.Row="3" Margin="0,0,0,8" />

        <!-- Hinweisbox (Inhalt wird per Code-behind gesetzt) -->
        <Border Grid.Row="4" x:Name="InfoBorder" BorderThickness="1" Padding="8,6">
            <TextBlock x:Name="InfoTextBlock" TextWrapping="Wrap" FontSize="11" />
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="OkButton" Content="Übernehmen" Width="100" Margin="0,0,6,0"
                    IsDefault="True" Click="OkButton_Click" />
            <Button Content="Schließen" Width="80" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
