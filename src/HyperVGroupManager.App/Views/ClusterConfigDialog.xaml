<Window x:Class="HyperVGroupManager.App.Views.ClusterConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen" Height="600" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">

            <!-- ── Tab 1: Cluster ─────────────────────────────────────────────── -->
            <TabItem Header="Cluster">
                <Grid Margin="12,10,12,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Aktueller ConfigStoreRootPath:" FontWeight="Bold" Margin="0,0,0,4" />
                    <Border Grid.Row="1" Background="#FFF0F0F0" BorderBrush="#FFCCCCCC" BorderThickness="1" Padding="6,4" Margin="0,0,0,12">
                        <TextBlock x:Name="CurrentPathTextBlock" TextWrapping="Wrap" Text="(wird geladen...)" Foreground="Gray" />
                    </Border>

                    <TextBlock Grid.Row="2" x:Name="NewPathLabel" Text="Neuer Pfad:" Margin="0,0,0,4" />
                    <TextBox x:Name="PathTextBox" Grid.Row="3" Margin="0,0,0,8" />

                    <Border Grid.Row="4" x:Name="InfoBorder" BorderThickness="1" Padding="8,6">
                        <TextBlock x:Name="InfoTextBlock" TextWrapping="Wrap" FontSize="11" />
                    </Border>

                    <Button Grid.Row="5" x:Name="OkButton" Content="Übernehmen" Width="100"
                            HorizontalAlignment="Right" Margin="0,10,0,0" Click="OkButton_Click" />
                </Grid>
            </TabItem>

            <!-- ── Tab 2: SMTP-Server ─────────────────────────────────────────── -->
            <TabItem Header="SMTP-Server">
                <Grid Margin="12,10,12,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="SMTP-Server:" VerticalAlignment="Center" Margin="0,0,8,8" />
                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="SmtpHostTextBox" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:" VerticalAlignment="Center" Margin="0,0,8,8" />
                    <TextBox   Grid.Row="1" Grid.Column="1" x:Name="SmtpPortTextBox" Width="80" HorizontalAlignment="Left" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Verschlüsselung:" VerticalAlignment="Center" Margin="0,0,8,8" />
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                        <RadioButton x:Name="SecurityNoneRadio"     Content="Keine"    GroupName="SmtpSec" Margin="0,0,14,0" />
                        <RadioButton x:Name="SecurityStartTlsRadio" Content="STARTTLS" GroupName="SmtpSec" Margin="0,0,14,0" IsChecked="True" />
                        <RadioButton x:Name="SecuritySslRadio"      Content="SSL/TLS"  GroupName="SmtpSec" />
                    </StackPanel>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Authentifizierung:" VerticalAlignment="Center" Margin="0,0,8,8" />
                    <CheckBox  Grid.Row="3" Grid.Column="1" x:Name="UseAuthCheckBox" Content="Benutzername und Passwort" VerticalAlignment="Center"
                               Margin="0,0,0,8" Checked="UseAuthCheckBox_Changed" Unchecked="UseAuthCheckBox_Changed" />

                    <TextBlock Grid.Row="4" Grid.Column="0" x:Name="UsernameLabel" Text="Benutzername:" VerticalAlignment="Center" Margin="0,0,8,8" />
                    <TextBox   Grid.Row="4" Grid.Column="1" x:Name="UsernameTextBox" IsEnabled="False" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="5" Grid.Column="0" x:Name="PasswordLabel" Text="Passwort:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <PasswordBox Grid.Row="5" Grid.Column="1" x:Name="PasswordBox" IsEnabled="False" />
                </Grid>
            </TabItem>

            <!-- ── Tab 3: E-Mail-Inhalt ───────────────────────────────────────── -->
            <TabItem Header="E-Mail-Inhalt">
                <Grid Margin="12,10,12,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Absender-Adresse:" VerticalAlignment="Center" Margin="0,0,8,8" />
                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="SenderAddressTextBox" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Anzeigename:" VerticalAlignment="Center" Margin="0,0,8,8" />
                    <TextBox   Grid.Row="1" Grid.Column="1" x:Name="SenderDisplayNameTextBox" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Empfänger:" VerticalAlignment="Top" Margin="0,4,8,0" />
                    <TextBox   Grid.Row="2" Grid.Column="1" x:Name="RecipientsTextBox" Height="80"
                               AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,2" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="(eine Adresse pro Zeile)"
                               FontSize="11" Foreground="Gray" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Nachrichtenvorspann:" VerticalAlignment="Top" Margin="0,4,8,0" />
                    <TextBox   Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                               x:Name="BodyPrefixTextBox" Height="80"
                               AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>

            <!-- ── Tab 4: Aufgabenplanung ─────────────────────────────────────── -->
            <TabItem Header="Aufgabenplanung">
                <Grid Margin="12,10,12,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ziel (Host/Cluster):" VerticalAlignment="Center" Margin="0,0,8,8" />
                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TargetNameTextBox" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tägliche Sendezeit:" VerticalAlignment="Center" Margin="0,0,8,8" />
                    <TextBox   Grid.Row="1" Grid.Column="1" x:Name="ScheduleTimeTextBox" Width="80"
                               HorizontalAlignment="Left" Margin="0,0,0,8" ToolTip="Format: HH:mm, z.B. 08:00" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Aufgabenname:" VerticalAlignment="Center" Margin="0,0,8,8" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TaskNameTextBlock" VerticalAlignment="Center"
                               Margin="0,0,0,8" Foreground="Gray" />

                    <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                            x:Name="StatusBorder" BorderThickness="1" Padding="8,6" Margin="0,4,0,8">
                        <TextBlock x:Name="TaskStatusTextBlock" TextWrapping="Wrap" FontSize="11" />
                    </Border>

                    <WrapPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                        <Button x:Name="RegisterTaskButton"   Content="Aufgabe registrieren" Width="150" Margin="0,0,6,0" Padding="4,3" Click="RegisterTaskButton_Click" />
                        <Button x:Name="UnregisterTaskButton" Content="Aufgabe entfernen"    Width="130" Margin="0,0,6,0" Padding="4,3" Click="UnregisterTaskButton_Click" />
                        <Button x:Name="RefreshStatusButton"  Content="Status aktualisieren" Width="140" Padding="4,3"               Click="RefreshStatusButton_Click" />
                    </WrapPanel>

                    <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" TextWrapping="Wrap"
                               FontSize="11" Foreground="Gray" VerticalAlignment="Bottom"
                               Text="Der Bericht wird täglich zur angegebenen Uhrzeit gesendet und listet alle VMs auf, die keiner Hyper-V-Gruppe zugeordnet sind. Die Aufgabe läuft unter dem aktuellen Windows-Benutzerkonto." />
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ── Schaltflächen unten ────────────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="SendNowButton" Content="Jetzt senden" Width="110" Margin="0,0,6,0" Padding="4" Click="SendNowButton_Click" />
            <Button x:Name="SaveButton"    Content="Speichern"    Width="90"  Margin="0,0,6,0" Padding="4" Click="SaveButton_Click" />
            <Button Content="Schließen"    Width="80" IsCancel="True" Padding="4" />
        </StackPanel>
    </Grid>
</Window>
